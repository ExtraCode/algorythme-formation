{% extends 'base.html.twig' %}

{% block title %}Les formations - {{ APP_NOM_OF }} {% endblock %}

{% block body %}
    <!-- Les formations -->
    <section class="learn-press-profile-section section section-padding">
        <div class="container">

            <h1 class="text-center">L'ensemble de nos formations,<br>dédiées aux professionnels.</h1>

            <section class="mt-5">

                <div class="learn-press-profile-nav">
                    <ul class="nav">
                        {% for categorie, sousCategories  in formationsParCategorie %}

                            <li>
                                <a {{ loop.first ? 'class="active"' : '' }}
                                    data-bs-toggle="tab"
                                    href="#categorie{{ loop.index }}">

                                    {{ categorie }}
                                </a>
                            </li>
                        {% endfor %}
                    </ul>
                </div>

            </section>

            {# Catégorie de la formation #}
            <div class="tab-content">
                {% for categorie, sousCategories in formationsParCategorie %}

                    <div id="categorie{{ loop.index }}"
                         class="tab-pane fade {{ loop.first ? 'active show' : '' }}">

                        {# Sous-catégories #}
                        <ul class="lp-tab-menu nav">
                            {% for sousCategorie, formations in sousCategories %}
                                {% set tabId = 'souscategorie-' ~ loop.parent.loop.index ~ '-' ~ loop.index %}

                                <li>
                                    <a class="{{ loop.first ? 'active' : '' }}"
                                       data-bs-toggle="tab"
                                       href="#{{ tabId }}"
                                       aria-selected="{{ loop.first ? 'true' : 'false' }}"
                                       role="tab">
                                        {{ sousCategorie }}
                                    </a>
                                </li>
                            {% endfor %}
                        </ul>

                        {# Formations par sous-catégorie #}
                        <div class="tab-content">
                            {% for sousCategorie, formations in sousCategories %}
                                {% set tabId = 'souscategorie-' ~ loop.parent.loop.index ~ '-' ~ loop.index %}

                                <div id="{{ tabId }}"
                                     class="tab-pane fade {{ loop.first ? 'active show' : '' }}"
                                     role="tabpanel">

                                    <table class="lp-list-table table">
                                        <thead>
                                        <tr>
                                            <th>Formation</th>
                                            <th>Durée</th>
                                            <th>Niveau</th>
                                            <th>Prix</th>
                                            <th>Note moyenne</th>
                                            <th>Action</th>
                                        </tr>
                                        </thead>

                                        <tbody>
                                        {% for produitFormation in formations %}
                                            <tr>
                                                <td>
                                                    {{ produitFormation.description.nom ?? produitFormation.description.titre ?? produitFormation.customId ?? 'Formation' }}
                                                </td>

                                                <td>
                                                    {% set duree = produitFormation.description.dureeDeLaFormation ?? null %}
                                                    {% if duree %}
                                                        {{ duree }} jour{{ duree > 1 ? 's' : '' }}
                                                    {% endif %}
                                                </td>

                                                <td>
                                                    {{ produitFormation.custom_fields.custom_field_7 ?? '-' }}
                                                </td>

                                                <td>
                                                    {% set prixHT = produitFormation.presetTarification.tarifs[0].budget[0].prixUnitaireHT ?? null %}
                                                    {% if prixHT %}
                                                        {{ prixHT|number_format(0, ',', ' ') }}€ HT
                                                    {% endif %}
                                                </td>

                                                <td>
                                                    {% set note = (produitFormation.custom_fields.custom_field_5 ?? 0) + 0 %}
                                                    {% if note %}
                                                        {{ note|number_format(1, ',', ' ') }}/5
                                                    {% endif %}
                                                </td>

                                                <td>
                                                    {# Mets ici ton lien API si tu en as un #}
                                                    <a href="#"
                                                       class="btn btn-primary btn-v-sm">
                                                        Voir la formation
                                                    </a>
                                                </td>
                                            </tr>
                                        {% endfor %}
                                        </tbody>
                                    </table>

                                </div>
                            {% endfor %}
                        </div>

                    </div>

                {% endfor %}
            </div>

        </div>
    </section>
{% endblock %}
