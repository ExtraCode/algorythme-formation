{% extends 'base.html.twig' %}

{% block title %}{{ APP_NOM_OF }} - Organisme de formation spécialisé dans l'intelligence artificielle{% endblock %}

{% block meta_description %}
    Organisme de formation spécialisé en intelligence artificielle et en informatique, basé dans le Sud-Ouest.
    Formations pratiques et adaptées aux entreprises pour maîtriser les outils IA dans l'informatique et booster votre performance.
{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/pages/accueil.scss') }}">
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/carte_salles.js') }}"></script>
{% endblock %}

{% block body %}

    {# Introduction #}
    <section class="intro2-section section">

        <div class="container">
            <div class="row row-cols-lg-2 row-cols-1 max-mb-n30">

                <div class="col align-self-center max-mb-30" data-aos="fade-up">
                    <div class="intro2-content text-center text-md-start">
                        <h1 class="title">Formations en Intelligence Artificielle</h1>
                        <div class="desc">
                            <p>Organisme de formation spécialisé en <strong>intelligence artificielle</strong>, basé à
                                Bordeaux,
                                <u>implanté</u> dans le sud ouest.
                                <br><u>Dédié</u> à la formation <strong>en informatique</strong> pour les
                                professionnels.
                            </p>
                        </div>

                        {# Barre de recherche #}
                        <div class="header-search-form mt-3">
                            <form action="#">
                                <label class="w-100">
                                    <input type="text" placeholder="Nom de formation, mots clés, ...">
                                </label>
                                <button><i class="fas fa-search"></i></button>
                            </form>
                        </div>

                        {# Vous avez des questions ? #}
                        <a class="link link-lg" href="{{ path('app_contact') }}"> Vous avez des questions ?
                            <mark>Contactez nous <i class="fas fa-arrow-right"></i></mark>
                        </a>
                    </div>
                </div>

                {# Photo animée #}
                <div class="col max-mb-30" data-aos="fade-up">
                    <div class="contact-image intro2-image">
                        <img src="{{ asset('images/algorythme-formation-flat.png') }}" width="78%"
                             alt="Algorythme Formation">

                        <div class="shape shape-1 scene">
                                <span data-depth="3">
                                    <img src="{{ asset('images/shape-animation/about-shape-1.png') }}" alt="forme">
                                </span>
                        </div>
                        <div class="shape shape-2 scene">
                            <span data-depth="-3"><img src="{{ asset('images/shape-animation/about-shape-1.png') }}"
                                                       alt="forme"></span>
                        </div>
                        <div class="shape shape-3 scene">
                            <span data-depth="4">shape 3</span>
                        </div>
                        <div class="shape shape-4 scene">
                            <span data-depth="4"><img src="{{ asset('images/shape-animation/shape-1.png') }}"
                                                      alt="forme"></span>
                        </div>
                        <div class="shape shape-5 scene">
                            <span data-depth="4"><img src="{{ asset('images/shape-animation/newsletter-shape-2.png') }}"
                                                      alt="forme"></span>
                        </div>
                    </div>
                </div>

            </div>
        </div>

    </section>

    {# Formations au top #}
    <section class="section section-padding" data-bg-color="#f5f7fa">
        <div class="container">

            <div class="section-title text-center" data-aos="fade-up">
                <span class="sub-title">Restez un collaborateur à jour !</span>
                <h2 class="title">Les formations qui cartonnent en ce moment</h2>
            </div>

            {# Liste des formations #}
            <div class="row row-cols-lg-3 row-cols-md-2 row-cols-1 max-mb-n30">

                {% for produitFormation in produitsFormation %}

                    {# Catégorie de la formation et couleur #}
                    {% if produitFormation.custom_fields is defined
                        and produitFormation.custom_fields.custom_field_4 is defined
                        and produitFormation.custom_fields.custom_field_4 %}

                        {% set categorie = produitFormation.custom_fields.custom_field_4 %}
                        {% set couleurCategorie = getCouleurByCategorieFormation(categorie) %}

                    {% endif %}

                    <!-- Formation Start -->
                    <div class="col max-mb-30 aos-init aos-animate" data-aos="fade-up">
                        <div class="course-2">

                            {# Header de la formation #}
                            <div class="formation__header">

                                {# Catégorie #}
                                {% if categorie is defined %}
                                    <p class="formation__categorie"
                                       style="background-color: {{ couleurCategorie }}">{{ categorie }}</p>
                                {% else %}
                                    <p class="formation__categorie">Informatique</p>
                                {% endif %}

                                {# Référence #}
                                {% if produitFormation.customId is defined and produitFormation.customId %}
                                    <p class="formation__reference">Ref : {{ produitFormation.customId }}</p>
                                {% endif %}

                            </div>

                            {# Contenu de la formation #}
                            <div class="info">

                                {# Nom de la formation #}
                                {% if produitFormation.meta is defined
                                    and produitFormation.meta.nom is defined
                                    and produitFormation.meta.nom %}
                                    <h3 class="title formation__titre">
                                        <a href="">{{ produitFormation.meta.nom }}</a>
                                    </h3>
                                {% endif %}

                                {# Tarifs #}
                                {% if produitFormation.presetTarification is defined
                                    and produitFormation.presetTarification.tarifs is defined
                                    and produitFormation.presetTarification.tarifs[0] is defined
                                    and produitFormation.presetTarification.tarifs[0].budget is defined
                                    and produitFormation.presetTarification.tarifs[0].budget[0] is defined
                                    and produitFormation.presetTarification.tarifs[0].budget[0].prixUnitaireHT is defined
                                    and produitFormation.presetTarification.tarifs[0].budget[0].prixUnitaireHT %}

                                    <span class="littleOne">
                                        {{ produitFormation.presetTarification.tarifs[0].budget[0].prixUnitaireHT }}€ HT
                                    </span>

                                {% endif %}

                                {# Nombre d'apprenants #}
                                {% if produitFormation.custom_fields is defined
                                    and produitFormation.custom_fields.custom_field_3 is defined
                                    and produitFormation.custom_fields.custom_field_3 %}

                                    {% set nbApprenants = produitFormation.custom_fields.custom_field_3 %}

                                    <p>
                                        <small>
                                            {{ calculNbApprenants(nbApprenants) }}
                                            <i class="fa-solid fa-person"></i>
                                            formées en 2026.
                                        </small>
                                    </p>
                                {% endif %}

                                {# Durée de la formation #}
                                {% if produitFormation.description is defined
                                    and produitFormation.description.dureeDeLaFormation is defined
                                    and produitFormation.description.dureeDeLaFormation %}

                                    {% set nbJours = produitFormation.description.dureeDeLaFormation / 7 %}
                                    <span class="price formation__jours"
                                          style="background-color: {{ couleurCategorie is defined ? couleurCategorie : "grey" }}">{{ nbJours }} jr{{ nbJours == 1 ? '' : 's' }}
                                </span>
                                {% endif %}

                                {# Nombre d'étoiles #}
                                {% if produitFormation.custom_fields is defined
                                    and produitFormation.custom_fields.custom_field_5 is defined
                                    and produitFormation.custom_fields.custom_field_5 %}

                                    {% set note = (produitFormation.custom_fields.custom_field_5 ?? 0) + 0 %}

                                    {% set fullStars = note|round(0, 'floor') %}
                                    {% set hasHalfStar = (note - fullStars) >= 0.5 %}
                                    {% set emptyStars = 5 - fullStars - (hasHalfStar ? 1 : 0) %}

                                    <div class="stars">
                                        {# étoiles pleines #}
                                        {% for i in 1..fullStars %}
                                            <i class="fa-solid fa-star"></i>
                                        {% endfor %}

                                        {# demi étoile #}
                                        {% if hasHalfStar %}
                                            <i class="fa-solid fa-star-half-stroke"></i>
                                        {% endif %}

                                        {# étoiles vides (sécurisé) #}
                                        {% if emptyStars > 0 %}
                                            {% for i in 1..emptyStars %}
                                                <i class="fa-regular fa-star"></i>
                                            {% endfor %}
                                        {% endif %}

                                        <span>{{ note|number_format(1, '.', '') }}/5</span>
                                    </div>

                                {% endif %}

                            </div>
                        </div>
                    </div>

                {% endfor %}

            </div>

            {# Bouton pour toutes les formations #}
            <div class="row max-mt-50">
                <div class="col text-center">
                    <a href="{{ path('app_formation') }}" class="btn btn-primary btn-hover-secondary"> Toutes les
                        formations
                        <i class="fas fa-arrow-right ms-3"></i>
                    </a>
                </div>
            </div>

        </div>
    </section>

    {# Salles de formations #}
    <section class="learners-section section section-padding">
        <div class="container">

            <div class="section-title text-center aos-init aos-animate" data-aos="fade-up">
                <h2 class="title">Nos salles de formation</h2>
                <span class="sub-title">Pas présent dans votre ville ? Contactez nous pour en parler.</span>
            </div>


            {# La map #}
            <div class="row">

                <div class="col-6 text-center salles__carte">
                    <img src="{{ asset('images/carte_france_region.png') }}" class="salles__carte__img"
                         alt="salles en région">
                    <i class="fa-solid fa-map-pin salles__carte__pin salles__carte__pin--bordeaux active"></i>
                    <i class="fa-solid fa-map-pin salles__carte__pin salles__carte__pin--toulouse"></i>
                    <i class="fa-solid fa-map-pin salles__carte__pin salles__carte__pin--paris"></i>
                </div>

                <div class="col-6 ps-4">

                    {# Bordeaux #}
                    <div class="salles__informations bordeaux active">
                        <h3 class="salles__informations__titre">Bordeaux</h3>
                        <p class="salles__informations__texte">
                            Situé dans la zone économique de Mérignac, à proximité de l'aéroport et de la gare, notre
                            centre de formation est pensé pour assurer un accueil optimal.
                        </p>
                        <p class="salles__informations__texte">
                            Tous nos espaces sont adaptés à de petits groupes comme des plus larges allant jusqu'à 25
                            collaborateurs.
                        </p>
                        <p class="salles__informations__texte">
                            6 salles de formations équipées, une salle de pause (frigo, micro-onde) pour déjeuner sur
                            place.
                        </p>
                        <a href="{{ path('app_formation') }}" class="btn btn-primary btn-hover-secondary">
                            Voir les formations</a>
                    </div>

                    {# Paris #}
                    <div class="salles__informations paris">
                        <h3 class="salles__informations__titre">Paris</h3>
                        <p class="salles__informations__texte">À quelques pas du Palais Garnier, nos 4 salles de
                            formations sont équipées de tout le matériel nécessaire à la parfaite réalisation de votre
                            formation.
                        </p>
                        <p class="salles__informations__texte">
                            Tous nos espaces sont adaptés à de petits groupes comme des plus larges allant jusqu'à 25
                            collaborateurs.
                        </p>
                        <p class="salles__informations__texte">
                            3 salles de formations équipées, une salle de pause (frigo, micro-onde) pour déjeuner sur
                            place.
                        </p>
                        <a href="{{ path('app_formation') }}" class="btn btn-primary btn-hover-secondary btn-sm"> Voir
                            les formations</a>
                    </div>

                    {# Toulouse #}
                    <div class="salles__informations toulouse">
                        <h3 class="salles__informations__titre">Toulouse</h3>
                        <p class="salles__informations__texte">
                            Implanté proche de la gare, notre centre de Toulouse permet d'accueil vos équipes en toute
                            convivialité.
                        </p>
                        <p class="salles__informations__texte">
                            Tous nos espaces sont adaptés à de petits groupes comme des plus larges allant jusqu'à 25
                            collaborateurs.
                        </p>
                        <p class="salles__informations__texte">
                            4 salles de formations équipées, une salle de pause (frigo, micro-onde) pour déjeuner sur
                            place.
                        </p>
                        <a href="{{ path('app_formation') }}" class="btn btn-primary btn-hover-secondary btn-sm"> Voir
                            les formations</a>
                    </div>

                </div>

            </div>

        </div>
    </section>

{% endblock %}
